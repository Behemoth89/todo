generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  username     String    @unique
  passwordHash String    @map("password_hash")
  name         String
  createdAt    DateTime  @default(now()) @map("created_at")
  deletedAt    DateTime? @map("deleted_at")
  version      Int       @default(1)

  assignees    TodoAssignee[]
  boughtItems  ShoppingItem[] @relation("BoughtBy")

  @@map("users")
}

model Todo {
  id             String    @id @default(uuid())
  title          String
  description    String?
  priorityId     String?   @map("priority_id")
  locationId     String?   @map("location_id")
  parentTodoId   String?   @map("parent_todo_id")
  startDate      DateTime? @map("start_date")
  dueDate        DateTime? @map("due_date")
  completionDate DateTime? @map("completion_date")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  version        Int       @default(1)

  priority     Settings?  @relation("TodoPriority", fields: [priorityId], references: [id])
  location     Settings?  @relation("TodoLocation", fields: [locationId], references: [id])
  parentTodo   Todo?      @relation("TodoParent", fields: [parentTodoId], references: [id])
  childTodos   Todo[]     @relation("TodoParent")
  assignees    TodoAssignee[]
  photos       Photo[]
  shoppingItems ShoppingItem[]

  @@index([deletedAt])
  @@index([priorityId])
  @@index([locationId])
  @@index([parentTodoId])
  @@index([completionDate])
  @@index([dueDate])
  @@map("todos")
}

model TodoAssignee {
  id      String @id @default(uuid())
  todoId  String @map("todo_id")
  userId  String @map("user_id")

  todo Todo  @relation(fields: [todoId], references: [id], onDelete: Cascade)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([todoId, userId])
  @@map("todo_assignees")
}

model Photo {
  id                String   @id @default(uuid())
  todoId            String   @map("todo_id")
  originalFilename   String   @map("original_filename")
  storedFilename     String   @map("stored_filename")
  filePath          String   @map("file_path")
  fileSizeBytes     Int      @map("file_size_bytes")
  createdAt         DateTime @default(now()) @map("created_at")
  deletedAt         DateTime? @map("deleted_at")
  version           Int      @default(1)

  todo Todo @relation(fields: [todoId], references: [id], onDelete: Cascade)

  @@index([todoId])
  @@index([deletedAt])
  @@map("photos")
}

model ShoppingItem {
  id          String    @id @default(uuid())
  todoId      String    @map("todo_id")
  description String
  amount      String?
  price       Float?
  notes       String?
  isBought    Boolean   @default(false) @map("is_bought")
  boughtById  String?   @map("bought_by_id")
  boughtAt    DateTime? @map("bought_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")
  version     Int       @default(1)

  todo    Todo   @relation(fields: [todoId], references: [id], onDelete: Cascade)
  boughtBy User?  @relation("BoughtBy", fields: [boughtById], references: [id])

  @@index([todoId])
  @@index([isBought])
  @@index([deletedAt])
  @@map("shopping_items")
}

model Settings {
  id        String    @id @default(uuid())
  category  String
  name      String
  sortOrder Int?      @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  version   Int       @default(1)

  todosAsPriority Settings[] @relation("TodoPriority")
  todosAsLocation Settings[] @relation("TodoLocation")

  @@unique([category, name])
  @@map("settings")
}