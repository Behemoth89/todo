generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  familyMembers FamilyMember[]
  todos         Todo[]
  locations    Location[]
  priorities  Priority[]

  @@map("users")
}

model FamilyMember {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  name      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignee  TodoAssignee[]

  @@map("family_members")
}

model Location {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  name     String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  todos Todo[]

  @@map("locations")
}

model Priority {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  name      String
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  todos Todo[]

  @@map("priorities")
}

model Todo {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  title         String
  description   String?
  priorityId    String?   @map("priority_id")
  locationId    String?   @map("location_id")
  startDate     DateTime?  @map("start_date")
  dueDate      DateTime?  @map("due_date")
  notes         String?
  completedAt   DateTime? @map("completed_at")
  readyToExecute Boolean  @default(false) @map("ready_to_execute")
  parentId      String?   @map("parent_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  priority  Priority?     @relation(fields: [priorityId], references: [id])
  location  Location?     @relation(fields: [locationId], references: [id])
  assignees  TodoAssignee[]
  photos    Photo[]
  shoppingItems ShoppingItem[]
  parent    Todo?       @relation("TodoChildren", fields: [parentId], references: [id])
  children  Todo[]     @relation("TodoChildren")

  @@map("todos")
}

model TodoAssignee {
  id             String   @id @default(cuid())
  todoId          String  @map("todo_id")
  familyMemberId  String  @map("family_member_id")
  createdAt      DateTime @default(now()) @map("created_at")

  todo           Todo          @relation(fields: [todoId], references: [id], onDelete: Cascade)
  familyMember   FamilyMember  @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)

  @@unique([todoId, familyMemberId])
  @@map("todo_assignees")
}

model Photo {
  id         String    @id @default(cuid())
  todoId     String    @map("todo_id")
  data       Bytes     // Full image in WebP format
  thumbnail  Bytes     // 150x150 thumbnail
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  todo       Todo      @relation(fields: [todoId], references: [id], onDelete: Cascade)

  @@map("photos")
}

model ShoppingItem {
  id          String    @id @default(cuid())
  todoId      String    @map("todo_id")
  description String
  amount     Int?
  price      Decimal?  @map("price")
  notes      String?
  boughtAt   DateTime? @map("bought_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  todo       Todo      @relation(fields: [todoId], references: [id], onDelete: Cascade)

  @@map("shopping_items")
}